{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://stackwarden.dev/schemas/config.schema.json",
	"title": "StackWarden repository config",
	"type": "object",
	"required": ["$schema", "version", "name", "recommendationPolicy", "material", "governance", "continuousImprovement"],
	"additionalProperties": true,
	"properties": {
		"$schema": { "type": "string" },
		"version": { "const": 1 },
		"name": { "const": "stackwarden-config" },
		"recommendationPolicy": {
			"type": "object",
			"required": ["defaultSeverity", "blockOnRecommendedConfigMissing", "explainWhenConfigWouldImproveSignal"],
			"properties": {
				"defaultSeverity": { "enum": ["advisory", "warning", "error"] },
				"blockOnRecommendedConfigMissing": { "type": "boolean" },
				"explainWhenConfigWouldImproveSignal": { "type": "boolean" }
			}
		},
		"material": { "type": "object" },
		"qualityContract": {
			"type": "object",
			"properties": {
				"requiredScripts": { "type": "array", "items": { "type": "string" } },
				"validationCommands": { "type": "array", "items": { "type": "string" } },
				"rationale": { "type": "string" }
			}
		},
		"governance": { "type": "object" },
		"continuousImprovement": {
			"type": "object",
			"properties": {
				"preCommitFastAudit": { "$ref": "#/$defs/blockableCheck" },
				"commitSize": { "$ref": "#/$defs/blockableCheck" },
				"envDrift": { "$ref": "#/$defs/blockableCheck" },
				"documentationDrift": { "$ref": "#/$defs/blockableCheck" },
				"affectedChecks": { "type": "object" }
			}
		},
		"rules": {
			"type": "object",
			"additionalProperties": {
				"type": "object",
				"properties": {
					"enabled": { "type": "boolean" },
					"severity": { "enum": ["info", "warning", "error"] },
					"blocking": { "type": "boolean" },
					"reason": { "type": "string" }
				}
			}
		}
	},
	"$defs": {
		"blockableCheck": {
			"type": "object",
			"properties": {
				"enabled": { "type": "boolean" },
				"blocking": { "type": "boolean" },
				"recommended": { "type": "boolean" },
				"command": { "type": "string" },
				"warnFiles": { "type": "number" },
				"warnLines": { "type": "number" },
				"failFiles": { "type": "number" },
				"failLines": { "type": "number" }
			}
		}
	}
}
