{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://stackwarden.dev/schemas/open-core-model.schema.json",
	"title": "StackWarden open-core model source of truth",
	"type": "object",
	"required": [
		"$schema",
		"schemaVersion",
		"name",
		"sourceOfTruth",
		"generatedDocument",
		"principles",
		"tiers",
		"localGuarantees",
		"configFiles",
		"jsonContract"
	],
	"additionalProperties": false,
	"properties": {
		"$schema": { "type": "string" },
		"schemaVersion": { "const": 1 },
		"name": { "const": "stackwarden-open-core-model" },
		"sourceOfTruth": { "type": "string" },
		"generatedDocument": { "type": "string" },
		"principles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
		"tiers": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["name", "visibility", "execution", "includedInPackage", "description", "examples"],
				"additionalProperties": false,
				"properties": {
					"name": { "type": "string" },
					"visibility": { "enum": ["full", "summary", "score_only", "masked"] },
					"execution": { "enum": ["local", "local-or-remote", "server"] },
					"includedInPackage": { "type": "boolean" },
					"description": { "type": "string" },
					"examples": { "type": "array", "items": { "type": "string" } }
				}
			}
		},
		"localGuarantees": { "type": "array", "items": { "type": "string" } },
		"configFiles": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["path", "purpose"],
				"additionalProperties": false,
				"properties": {
					"path": { "type": "string" },
					"purpose": { "type": "string" }
				}
			}
		},
		"jsonContract": { "type": "object" }
	}
}
